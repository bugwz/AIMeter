{
  "name": "aimeter",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:all": "concurrently \"npm run start:server\" \"npm run dev\"",
    "dev:mock:all": "concurrently \"AIMETER_MOCK_ENABLED=true npm run start:server\" \"npm run dev\"",
    "build": "tsc --noEmit --skipLibCheck && vite build",
    "lint": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "preview": "vite preview",
    "cf:build": "npm run build",
    "cf:dev": "npx wrangler dev",
    "cf:deploy": "npx wrangler deploy",
    "start:server": "node --import tsx server/index.ts",
    "start:mock": "AIMETER_MOCK_ENABLED=true node --import tsx server/index.ts",
    "vercel-build": "node scripts/vercel-build.mjs"
  },
  "dependencies": {
    "@resvg/resvg-js": "^2.6.2",
    "axios": "^1.6.0",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "mysql2": "^3.19.0",
    "node-cron": "^3.0.3",
    "pg": "^8.20.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^7.13.1",
    "recharts": "^2.10.0",
    "uuid": "^9.0.0",
    "zustand": "^4.4.0"
  },
  "optionalDependencies": {
    "better-sqlite3": "^9.2.2"
  },
  "overrides": {
    "iconv-lite": "^0.6.3"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.8",
    "@types/express": "^4.17.21",
    "@types/node-cron": "^3.0.11",
    "@types/pg": "^8.18.0",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@types/uuid": "^9.0.7",
    "@vitejs/plugin-react": "^4.2.0",
    "autoprefixer": "^10.4.0",
    "concurrently": "^8.2.2",
    "postcss": "^8.4.0",
    "tailwindcss": "^3.4.0",
    "tsx": "^4.7.0",
    "typescript": "^5.3.0",
    "vite": "^5.0.0"
  }
}
