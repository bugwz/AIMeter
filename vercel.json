{
  "buildCommand": "npm run vercel-build",
  "outputDirectory": "dist",
  "functions": {
    "api/index.ts": {
      "maxDuration": 30,
      "memory": 512,
      "includeFiles": [
        "dist/index.html",
        "node_modules/pg/**",
        "node_modules/pg-pool/**",
        "node_modules/pg-protocol/**",
        "node_modules/pg-types/**"
      ]
    }
  },
  "rewrites": [
    { "source": "/api/:path*", "destination": "/api/index" },
    { "source": "/((?!api/).*)", "destination": "/api/index" }
  ]
}
