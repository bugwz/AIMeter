# AIMeter environment overrides
# Priority: config.yaml > environment variables > built-in defaults
# All variables are optional unless noted.
#
# Config file loading
# Allowed:
# - relative file path: resolved from the project root
# - absolute file path: used as-is
# Default when unset:
# - use ./config.yaml if that file exists
# - otherwise no config file is loaded
# Example:
# AIMETER_CONFIG_FILE=./config.yaml

# API base path or absolute API URL.
# Allowed:
# - URL path, for example /api: use the same host as the frontend
# - absolute URL, for example https://api.example.com: call a separate backend origin
# Applied when config.yaml key is unset: server.apiUrl
# Built-in default when unset in both env and config.yaml: /api
AIMETER_API_URL=/api

# Vite dev server port for local development.
# Allowed:
# - any positive integer port, for example 3000
# Applied when config.yaml key is unset: server.frontendPort
# Built-in default when unset in both env and config.yaml: 3000
AIMETER_FRONTEND_PORT=3000

# Server
# Backend HTTP server listen port.
# Allowed:
# - any positive integer port, for example 3001
# Applied when config.yaml key is unset: server.backendPort
# Built-in default when unset in both env and config.yaml: 3001
AIMETER_BACKEND_PORT=3001

# Public protocol used by the deployed service.
# Allowed:
# - http: local/non-TLS deployment
# - https: TLS-terminated deployment (enables HSTS + Secure cookies)
# Applied when config.yaml key is unset: server.protocol
# Built-in default when unset in both env and config.yaml:
# - https when AIMETER_RUNTIME_MODE=serverless
# - http otherwise
AIMETER_SERVER_PROTOCOL=http

# Allowed CORS origins for browser requests.
# Allowed:
# - single origin, for example http://localhost:3000
# - comma-separated origin list, for example http://localhost:3000,https://your-domain.com
# Applied when config.yaml key is unset: server.corsOrigins
# Built-in default when unset in both env and config.yaml: empty (no custom CORS middleware)
# Example:
# AIMETER_CORS_ORIGIN=http://localhost:3000,https://your-domain.com

# Runtime
# Switch all provider data fetching to mock mode.
# Allowed:
# - true: all provider usage comes from mock data
# - false: all provider usage comes from live adapters
# Built-in default when unset in both env and config.yaml: false
AIMETER_MOCK_ENABLED=false

# Select the process runtime model.
# Allowed:
# - node: enable in-process scheduler (node-cron)
# - serverless: disable in-process scheduler; refresh is request-triggered only
# Built-in default when unset in both env and config.yaml: node
AIMETER_RUNTIME_MODE=node

# Database
# Enable or disable database-backed mode.
# Allowed:
# - true: provider config comes from database; history is persisted
# - false: provider config comes from AIMETER_PROVIDERS_JSON; history is disabled
# Built-in default when unset in both env and config.yaml: true
AIMETER_DATABASE_ENABLED=true

# Select database engine.
# Allowed:
# - sqlite: use a local SQLite database file
# - postgres: use a PostgreSQL database via DSN connection string
# - mysql: use a MySQL database via DSN connection string
# Built-in default when unset in both env and config.yaml: sqlite
AIMETER_DATABASE_ENGINE=sqlite

# Main database connection string.
# Allowed:
# - sqlite file path, for example ./data/aimeter.db: store data in a local SQLite file
# - postgres DSN, for example postgresql://postgres:password@127.0.0.1:5432/aimeter
# - mysql DSN, for example mysql://root:password@127.0.0.1:3306/aimeter
# Built-in default when unset in both env and config.yaml: ./data/aimeter.db
AIMETER_DATABASE_CONNECTION=./data/aimeter.db
# Examples by engine:
# AIMETER_DATABASE_CONNECTION=./data/aimeter.db
# AIMETER_DATABASE_CONNECTION=mysql://root:password@127.0.0.1:3306/aimeter
# AIMETER_DATABASE_CONNECTION=postgresql://postgres:password@127.0.0.1:5432/aimeter

# Encrypt provider credentials stored in the main database.
# Allowed:
# - any non-empty string: used as the encryption secret
# Default when unset in database mode: auto-generated on first start and stored in the database
# Default when unset in env mode: ignored
# In database mode this value is ignored; encryption key is managed in DB.
# Example:
# AIMETER_ENCRYPTION_KEY=

# Authentication
# Sign authentication session cookies.
# Allowed:
# - any non-empty string: used to sign session cookies
# Default when unset in database mode: auto-generated on first start and stored in the database
# Default when unset in env mode: startup validation fails
# In database mode this value is ignored; secret is managed in DB.
# Example:
# AIMETER_AUTH_SESSION_SECRET=

# Session cookie lifetime in seconds.
# Allowed:
# - any positive integer: session lifetime in seconds
# Built-in default when unset in both env and config.yaml: 43200 (12 hours)
AIMETER_AUTH_SESSION_TTL_SECONDS=43200

# Read-only normal-entry password source when database mode is disabled.
# Allowed:
# - plaintext password string: enable normal-entry password verification from env/config
# Password format requirement:
# - at least 12 characters
# - contains at least one letter
# - contains at least one digit
# Default when unset in both env and config.yaml: unset
# If unset in non-database mode, normal entry login cannot be completed
# Example:
# AIMETER_NORMAL_PASSWORD=replace-with-normal-password

# Read-only admin-entry password source when database mode is disabled.
# Allowed:
# - plaintext password string: enable admin-entry password verification from env/config
# Password format requirement:
# - at least 12 characters
# - contains at least one letter
# - contains at least one digit
# Default when unset in both env and config.yaml: unset
# If unset in non-database mode, admin entry login cannot be completed
# Example:
# AIMETER_ADMIN_PASSWORD=replace-with-admin-password

# Admin route secret used for the management entry URL.
# Allowed:
# - exactly 32 random characters: admin UI is served from http://host:3000/<secret>
# Default when unset in env mode: startup validation fails
# In database mode this value is ignored; admin route path is managed during bootstrap and stored in DB.
# Recommended: generate a high-entropy random string and keep it private
# Example:
# AIMETER_ADMIN_ROUTE_PATH=replace-with-32-char-random-secret

# Shared secret for external cron/webhook refresh jobs (serverless friendly).
# Allowed:
# - exactly 32 random characters: caller must send this value in X-AIMETER-CRON-SECRET
# Default when unset in both env and config.yaml:
# - env storage mode: unset (cron endpoint disabled)
# - database storage mode: auto-generated on first start and stored in database
# Note: in database mode this value is used only during first-time initialization; existing DB value is not overridden.
# Example:
# AIMETER_CRON_SECRET=replace-with-32-char-random-secret

# Shared secret for external script access to /api/endpoint/subscriptions.
# Allowed:
# - exactly 32 random characters: caller must send this value in X-AIMETER-ENDPOINT-SECRET
# Default when unset in both env and config.yaml:
# - env storage mode: unset (secret-based access disabled)
# - database storage mode: auto-generated on first start and stored in database
# Note: in database mode this value is used only during first-time initialization; existing DB value is not overridden.
# Example:
# AIMETER_ENDPOINT_SECRET=replace-with-32-char-random-secret

# Antigravity OAuth
# OAuth client ID used for Antigravity Google token refresh.
# Allowed:
# - any non-empty OAuth client ID string
# Built-in default when unset: Antigravity official client ID
# Example:
# ANTIGRAVITY_OAUTH_CLIENT_ID=1071006060591-xxxxx.apps.googleusercontent.com

# OAuth client secret used for Antigravity code exchange and token refresh.
# Allowed:
# - any non-empty OAuth client secret string
# Required when using Antigravity OAuth link exchange or refresh flow.
# Example:
# ANTIGRAVITY_OAUTH_CLIENT_SECRET=replace-with-antigravity-client-secret

# Authentication rate limiting
# Rate-limit evaluation window length.
# Allowed:
# - any positive integer: window length in milliseconds
# Built-in default when unset in both env and config.yaml: 60000
AIMETER_AUTH_RATE_LIMIT_WINDOW_MS=60000

# Maximum allowed failed attempts within the rate-limit window.
# Allowed:
# - any positive integer: maximum failed attempts before blocking
# Built-in default when unset in both env and config.yaml: 5
AIMETER_AUTH_RATE_LIMIT_MAX_ATTEMPTS=5

# Temporary block duration after exceeding rate limit.
# Allowed:
# - any positive integer: block duration in milliseconds
# Built-in default when unset in both env and config.yaml: 300000
AIMETER_AUTH_RATE_LIMIT_BLOCK_MS=300000

# Provider configuration in env-only mode (database disabled)
# Required in env-only mode:
# - AIMETER_PROVIDERS_JSON: JSON array of provider objects
# Removed:
# - AIMETER_PROVIDER_IDS and AIMETER_PROVIDER__* are no longer supported
# - config.yaml providers block is no longer supported
# Example:
# AIMETER_PROVIDERS_JSON=[{"id":"primary","type":"cursor","authType":"cookie","credential":"replace-with-cursor-cookie","refreshInterval":5}]

# Main file-based configuration example:
# See config.example.yaml
